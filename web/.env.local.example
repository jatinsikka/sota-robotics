# Neon serverless Postgres — pooled connection string. SERVER-ONLY.
# NEVER prefix with NEXT_PUBLIC_: the web app reads the DB server-side only
# (App Router server components / route handlers), so this must not reach the
# browser bundle. Access control comes from queries filtering
# verification_status='published', not from RLS.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require

# Anthropic — server-side only. NEVER prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-xxx
